{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storybook.local/contracts/learning-journeys.schema.json",
  "title": "StoryBook Learning Journeys Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["journeys"],
  "properties": {
    "journeys": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/journey" }
    }
  },
  "$defs": {
    "journey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "sortOrder",
        "title",
        "summary",
        "learningGoals",
        "suggestedReadingMinutes",
        "ageGuidance",
        "storyReferences"
      ],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "sortOrder": {
          "type": "integer",
          "minimum": 1
        },
        "title": { "$ref": "#/$defs/localizedText" },
        "summary": { "$ref": "#/$defs/localizedText" },
        "learningGoals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "suggestedReadingMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "ageGuidance": { "$ref": "#/$defs/localizedText" },
        "storyReferences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/storyReference" }
        }
      }
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zhTW"],
      "properties": {
        "zhTW": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string"
        }
      }
    },
    "storyReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "slug", "sortOrder"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["dinosaurs", "aquarium"]
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "sortOrder": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}

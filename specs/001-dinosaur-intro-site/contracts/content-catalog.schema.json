{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storybook2.local/contracts/content-catalog.schema.json",
  "title": "StoryBook2 Dinosaur Content Catalog",
  "type": "object",
  "required": ["version", "profiles"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/dinosaurProfile" }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "required": ["zhTW", "en"],
      "additionalProperties": false,
      "properties": {
        "zhTW": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "illustration": {
      "type": "object",
      "required": ["path", "altText", "styleTag"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/images/dinosaurs/[a-z0-9-]+\\.(png|jpg|jpeg|webp)$"
        },
        "altText": { "$ref": "#/$defs/localizedText" },
        "caption": { "$ref": "#/$defs/localizedText" },
        "styleTag": {
          "type": "string",
          "const": "storybook-cute"
        }
      }
    },
    "dinosaurStory": {
      "type": "object",
      "required": ["title", "body", "illustration"],
      "additionalProperties": false,
      "properties": {
        "title": { "$ref": "#/$defs/localizedText" },
        "body": { "$ref": "#/$defs/localizedText" },
        "illustration": { "$ref": "#/$defs/illustration" }
      }
    },
    "dinosaurProfile": {
      "type": "object",
      "required": [
        "slug",
        "category",
        "sortOrder",
        "names",
        "periods",
        "diet",
        "discoveryLocations",
        "sizeDescription",
        "summary",
        "mainImage",
        "story",
        "searchKeywords"
      ],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "category": {
          "type": "string",
          "enum": ["dinosaur", "prehistoric-flying-reptile"]
        },
        "sortOrder": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "names": { "$ref": "#/$defs/localizedText" },
        "periods": { "$ref": "#/$defs/localizedText" },
        "diet": { "$ref": "#/$defs/localizedText" },
        "discoveryLocations": { "$ref": "#/$defs/localizedText" },
        "sizeDescription": { "$ref": "#/$defs/localizedText" },
        "summary": { "$ref": "#/$defs/localizedText" },
        "notDinosaurNote": { "$ref": "#/$defs/localizedText" },
        "mainImage": { "$ref": "#/$defs/illustration" },
        "story": { "$ref": "#/$defs/dinosaurStory" },
        "searchKeywords": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/localizedText" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "category": { "const": "prehistoric-flying-reptile" }
            }
          },
          "then": {
            "required": ["notDinosaurNote"]
          }
        }
      ]
    }
  }
}

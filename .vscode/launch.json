{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "StoryBook: Debug HTTP",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build StoryBook",
      "program": "${workspaceFolder}/StoryBook/bin/Debug/net10.0/StoryBook.dll",
      "args": [],
      "cwd": "${workspaceFolder}/StoryBook",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5059"
      }
    },
    {
      "name": "StoryBook: Debug HTTPS",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build StoryBook",
      "program": "${workspaceFolder}/StoryBook/bin/Debug/net10.0/StoryBook.dll",
      "args": [],
      "cwd": "${workspaceFolder}/StoryBook",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7111;http://localhost:5059"
      }
    },
    {
      "name": "StoryBook: Attach",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}

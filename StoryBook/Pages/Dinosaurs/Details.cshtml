@page "/dinosaurs/{slug}"
@model StoryBook.Pages.Dinosaurs.DetailsModel
@{
    ViewData["Title"] = Model.Profile?.Names.Get(LanguageCode.ZhTW) ?? "找不到恐龍";
}

<section class="dino-page" aria-labelledby="dino-detail-title">
    <div class="dino-page__header">
        <a class="dino-home-link" asp-page="/Index">回首頁</a>
    </div>

    @if (Model.IsNotFound || Model.Profile is null)
    {
        <div class="dino-empty" role="status">
            <h1 id="dino-detail-title">找不到這位史前朋友</h1>
            <p>這個網址沒有對應的恐龍資料。你可以回到清單重新選一位朋友。</p>
            <a class="dino-home-link" asp-page="/Index">回首頁</a>
            <a class="dino-action" asp-page="/Dinosaurs/Index">回恐龍介紹</a>
        </div>
    }
    else
    {
        <article class="dino-detail">
            <div class="dino-detail__media">
                <button class="dino-image-button"
                        type="button"
                        aria-label="@($"開啟{Model.Profile.Names.Get(LanguageCode.ZhTW)}大圖")"
                        data-dino-modal-open="dino-image-modal">
                    <img src="@Model.Profile.MainImage.Path"
                         alt="@Model.Profile.MainImage.AltText.Get(LanguageCode.ZhTW)" />
                </button>
                @if (Model.Profile.MainImage.Caption is not null)
                {
                    <p>@Model.Profile.MainImage.Caption.Get(LanguageCode.ZhTW)</p>
                }
            </div>
            <div class="dino-detail__body">
                <p class="dino-kicker">史前朋友</p>
                <h1 id="dino-detail-title">@Model.Profile.Names.Get(LanguageCode.ZhTW)</h1>
                <dl class="dino-facts">
                    <div>
                        <dt>生活時期</dt>
                        <dd>@Model.Profile.Periods.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt>食性</dt>
                        <dd>@Model.Profile.Diet.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt>發現地點</dt>
                        <dd>@Model.Profile.DiscoveryLocations.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt>體型</dt>
                        <dd>@Model.Profile.SizeDescription.Get(LanguageCode.ZhTW)</dd>
                    </div>
                </dl>
                <p class="dino-summary">@Model.Profile.Summary.Get(LanguageCode.ZhTW)</p>
                @if (Model.Profile.NotDinosaurNote is not null)
                {
                    <p class="dino-note">@Model.Profile.NotDinosaurNote.Get(LanguageCode.ZhTW)</p>
                }
                <section class="dino-story" aria-labelledby="dino-story-title">
                    <div class="dino-story__text">
                        <p class="dino-kicker">小故事</p>
                        <h2 id="dino-story-title">@Model.Profile.Story.Title.Get(LanguageCode.ZhTW)</h2>
                        <p>@Model.Profile.Story.Body.Get(LanguageCode.ZhTW)</p>
                    </div>
                    <figure class="dino-story__figure">
                        <img src="@Model.Profile.Story.Illustration.Path"
                             alt="@Model.Profile.Story.Illustration.AltText.Get(LanguageCode.ZhTW)" />
                        @if (Model.Profile.Story.Illustration.Caption is not null)
                        {
                            <figcaption>@Model.Profile.Story.Illustration.Caption!.Get(LanguageCode.ZhTW)</figcaption>
                        }
                    </figure>
                </section>
                <nav class="dino-pager" aria-label="恐龍換頁">
                    @if (Model.PreviousProfile is null)
                    {
                        <span class="dino-page-link dino-page-link--disabled" aria-disabled="true">上一頁</span>
                    }
                    else
                    {
                        <a class="dino-page-link" asp-page="/Dinosaurs/Details" asp-route-slug="@Model.PreviousProfile.Slug">
                            上一頁：@Model.PreviousProfile.Names.Get(LanguageCode.ZhTW)
                        </a>
                    }

                    @if (Model.NextProfile is null)
                    {
                        <span class="dino-page-link dino-page-link--disabled" aria-disabled="true">下一頁</span>
                    }
                    else
                    {
                        <a class="dino-page-link" asp-page="/Dinosaurs/Details" asp-route-slug="@Model.NextProfile.Slug">
                            下一頁：@Model.NextProfile.Names.Get(LanguageCode.ZhTW)
                        </a>
                    }
                </nav>
            </div>
        </article>

        <div class="modal fade dino-modal"
             id="dino-image-modal"
             tabindex="-1"
             aria-labelledby="dino-image-modal-title"
             aria-hidden="true"
             data-dino-modal>
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="dino-image-modal-title">@Model.Profile.Names.Get(LanguageCode.ZhTW)大圖</h2>
                        <button type="button"
                                class="btn-close"
                                aria-label="關閉大圖"
                                data-dino-modal-close></button>
                    </div>
                    <div class="modal-body">
                        <img class="dino-modal__image"
                             src="@Model.Profile.MainImage.Path"
                             alt="@Model.Profile.MainImage.AltText.Get(LanguageCode.ZhTW)" />
                        @if (Model.Profile.MainImage.Caption is not null)
                        {
                            <p class="dino-modal__caption">@Model.Profile.MainImage.Caption.Get(LanguageCode.ZhTW)</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</section>

@section Scripts {
    <script src="~/js/dinosaurs.js" asp-append-version="true"></script>
}

@page "/dinosaurs/{slug}"
@model StoryBook.Pages.Dinosaurs.DetailsModel
@{
    ViewData["Title"] = Model.Profile?.Names.Get(LanguageCode.ZhTW) ?? "找不到恐龍";
    if (Model.Profile is not null && !Model.IsNotFound)
    {
        ViewData["UsePassportAssets"] = true;
    }
}

<section class="dino-page" aria-labelledby="dino-detail-title">
    <div class="dino-page__header">
        <a class="dino-home-link" asp-page="/Dinosaurs/Index" data-i18n-zh-tw="回恐龍介紹" data-i18n-en="Back to dinosaurs">回恐龍介紹</a>
        <a class="dino-home-link" asp-page="/Index" data-i18n-zh-tw="回首頁" data-i18n-en="Home">回首頁</a>
    </div>

    @if (Model.IsNotFound || Model.Profile is null)
    {
        <div class="dino-empty" role="status">
            <h1 id="dino-detail-title" data-i18n-zh-tw="找不到這位史前朋友" data-i18n-en="This prehistoric friend was not found">找不到這位史前朋友</h1>
            <p data-i18n-zh-tw="這個網址沒有對應的恐龍資料。你可以回到清單重新選一位朋友。" data-i18n-en="This address does not match a dinosaur profile. You can return to the list and choose another friend.">這個網址沒有對應的恐龍資料。你可以回到清單重新選一位朋友。</p>
            <a class="dino-home-link" asp-page="/Index" data-i18n-zh-tw="回首頁" data-i18n-en="Home">回首頁</a>
            <a class="dino-action" asp-page="/Dinosaurs/Index" data-i18n-zh-tw="回恐龍介紹" data-i18n-en="Back to dinosaurs">回恐龍介紹</a>
        </div>
    }
    else
    {
        <article class="dino-detail">
            <div class="dino-detail__media">
                <button class="dino-image-button"
                        type="button"
                        aria-label="@($"開啟{Model.Profile.Names.Get(LanguageCode.ZhTW)}大圖")"
                        data-aria-label-zh-tw="@($"開啟{Model.Profile.Names.Get(LanguageCode.ZhTW)}大圖")"
                        data-aria-label-en="@($"Open large image for {Model.Profile.Names.Get(LanguageCode.En)}")"
                        data-dino-modal-open="dino-image-modal">
                    <img src="@Model.Profile.MainImage.Path"
                         alt="@Model.Profile.MainImage.AltText.Get(LanguageCode.ZhTW)"
                         data-alt-zh-tw="@Model.Profile.MainImage.AltText.Get(LanguageCode.ZhTW)"
                         data-alt-en="@Model.Profile.MainImage.AltText.Get(LanguageCode.En)" />
                </button>
                @if (Model.Profile.MainImage.Caption is not null)
                {
                    <p data-i18n-zh-tw="@Model.Profile.MainImage.Caption.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.MainImage.Caption.Get(LanguageCode.En)">@Model.Profile.MainImage.Caption.Get(LanguageCode.ZhTW)</p>
                }
            </div>
            <div class="dino-detail__body">
                <p class="dino-kicker" data-i18n-zh-tw="史前朋友" data-i18n-en="Prehistoric friend">史前朋友</p>
                <h1 id="dino-detail-title" data-i18n-zh-tw="@Model.Profile.Names.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Names.Get(LanguageCode.En)">@Model.Profile.Names.Get(LanguageCode.ZhTW)</h1>
                <dl class="dino-facts">
                    <div>
                        <dt data-i18n-zh-tw="生活時期" data-i18n-en="Period">生活時期</dt>
                        <dd data-i18n-zh-tw="@Model.Profile.Periods.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Periods.Get(LanguageCode.En)">@Model.Profile.Periods.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt data-i18n-zh-tw="食性" data-i18n-en="Diet">食性</dt>
                        <dd data-i18n-zh-tw="@Model.Profile.Diet.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Diet.Get(LanguageCode.En)">@Model.Profile.Diet.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt data-i18n-zh-tw="發現地點" data-i18n-en="Found in">發現地點</dt>
                        <dd data-i18n-zh-tw="@Model.Profile.DiscoveryLocations.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.DiscoveryLocations.Get(LanguageCode.En)">@Model.Profile.DiscoveryLocations.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt data-i18n-zh-tw="體型" data-i18n-en="Size">體型</dt>
                        <dd data-i18n-zh-tw="@Model.Profile.SizeDescription.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.SizeDescription.Get(LanguageCode.En)">@Model.Profile.SizeDescription.Get(LanguageCode.ZhTW)</dd>
                    </div>
                </dl>
                <p class="dino-summary" data-i18n-zh-tw="@Model.Profile.Summary.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Summary.Get(LanguageCode.En)">@Model.Profile.Summary.Get(LanguageCode.ZhTW)</p>
                @if (Model.Profile.NotDinosaurNote is not null)
                {
                    <p class="dino-note" data-i18n-zh-tw="@Model.Profile.NotDinosaurNote.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.NotDinosaurNote.Get(LanguageCode.En)">@Model.Profile.NotDinosaurNote.Get(LanguageCode.ZhTW)</p>
                }
                <section class="dino-story" aria-labelledby="dino-story-title">
                    <div class="dino-story__text">
                        <p class="dino-kicker" data-i18n-zh-tw="小故事" data-i18n-en="Story">小故事</p>
                        <h2 id="dino-story-title" data-i18n-zh-tw="@Model.Profile.Story.Title.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Story.Title.Get(LanguageCode.En)">@Model.Profile.Story.Title.Get(LanguageCode.ZhTW)</h2>
                        <p data-i18n-zh-tw="@Model.Profile.Story.Body.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Story.Body.Get(LanguageCode.En)">@Model.Profile.Story.Body.Get(LanguageCode.ZhTW)</p>
                    </div>
                    <figure class="dino-story__figure">
                        <img src="@Model.Profile.Story.Illustration.Path"
                             alt="@Model.Profile.Story.Illustration.AltText.Get(LanguageCode.ZhTW)"
                             data-alt-zh-tw="@Model.Profile.Story.Illustration.AltText.Get(LanguageCode.ZhTW)"
                             data-alt-en="@Model.Profile.Story.Illustration.AltText.Get(LanguageCode.En)" />
                        @if (Model.Profile.Story.Illustration.Caption is not null)
                        {
                            <figcaption data-i18n-zh-tw="@Model.Profile.Story.Illustration.Caption!.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.Story.Illustration.Caption!.Get(LanguageCode.En)">@Model.Profile.Story.Illustration.Caption!.Get(LanguageCode.ZhTW)</figcaption>
                        }
                    </figure>
                </section>
                <section class="passport-completion"
                         data-passport-story
                         data-passport-source="dinosaurs"
                         data-passport-slug="@Model.Profile.Slug"
                         data-passport-name-zh-tw="@Model.Profile.Names.Get(LanguageCode.ZhTW)"
                         data-passport-name-en="@Model.Profile.Names.Get(LanguageCode.En)"
                         data-passport-status-incomplete-zh-tw="讀完後可以把{0}蓋進你的探險護照。"
                         data-passport-status-incomplete-en="When you finish, you can stamp {0} in your passport."
                         data-passport-status-completed-zh-tw="已把{0}蓋進你的探險護照。"
                         data-passport-status-completed-en="{0} is stamped in your passport."
                         data-passport-status-already-completed-zh-tw="{0}已經在護照裡，不會重複計算。"
                         data-passport-status-already-completed-en="{0} is already in your passport and will not count twice."
                         data-passport-status-read-blocked-zh-tw="護照暫時打不開，但故事還可以繼續讀。"
                         data-passport-status-read-blocked-en="The passport cannot open right now, but you can keep reading."
                         data-passport-status-write-blocked-zh-tw="護照暫時不能蓋章，請稍後再試。"
                         data-passport-status-write-blocked-en="The passport cannot save this stamp right now. Please try again later."
                         data-passport-status-invalid-data-zh-tw="護照裡有看不懂的舊資料，下一次蓋章會整理好。"
                         data-passport-status-invalid-data-en="The passport has old data it cannot read. The next stamp will tidy it up.">
                    <h2 class="passport-completion__title" data-i18n-zh-tw="我的探險護照" data-i18n-en="My adventure passport">我的探險護照</h2>
                    <div class="passport-completion__actions">
                        <button class="passport-completion__button"
                                type="button"
                                data-passport-complete
                                aria-label="@($"把{Model.Profile.Names.Get(LanguageCode.ZhTW)}蓋到我的探險護照")"
                                data-aria-label-zh-tw="@($"把{Model.Profile.Names.Get(LanguageCode.ZhTW)}蓋到我的探險護照")"
                                data-aria-label-en="@($"Stamp {Model.Profile.Names.Get(LanguageCode.En)} in my passport")"
                                data-i18n-zh-tw="我讀完了"
                                data-i18n-en="I finished reading">我讀完了</button>
                        <a class="passport-completion__link"
                           href="/passport"
                           data-passport-link
                           data-i18n-zh-tw="我的探險護照"
                           data-i18n-en="My passport">我的探險護照</a>
                    </div>
                    <p class="passport-completion__status"
                       data-passport-status
                       role="status"
                       aria-live="polite">讀完後可以把@(Model.Profile.Names.Get(LanguageCode.ZhTW))蓋進你的探險護照。</p>
                </section>
                <nav class="dino-pager" aria-label="恐龍換頁" data-aria-label-zh-tw="恐龍換頁" data-aria-label-en="Dinosaur navigation">
                    @if (Model.PreviousProfile is null)
                    {
                        <span class="dino-page-link dino-page-link--disabled" aria-disabled="true" data-i18n-zh-tw="上一頁" data-i18n-en="Previous">上一頁</span>
                    }
                    else
                    {
                        <a class="dino-page-link" asp-page="/Dinosaurs/Details" asp-route-slug="@Model.PreviousProfile.Slug" data-i18n-zh-tw="上一頁：@Model.PreviousProfile.Names.Get(LanguageCode.ZhTW)" data-i18n-en="Previous: @Model.PreviousProfile.Names.Get(LanguageCode.En)">
                            上一頁：@Model.PreviousProfile.Names.Get(LanguageCode.ZhTW)
                        </a>
                    }

                    @if (Model.NextProfile is null)
                    {
                        <span class="dino-page-link dino-page-link--disabled" aria-disabled="true" data-i18n-zh-tw="下一頁" data-i18n-en="Next">下一頁</span>
                    }
                    else
                    {
                        <a class="dino-page-link" asp-page="/Dinosaurs/Details" asp-route-slug="@Model.NextProfile.Slug" data-i18n-zh-tw="下一頁：@Model.NextProfile.Names.Get(LanguageCode.ZhTW)" data-i18n-en="Next: @Model.NextProfile.Names.Get(LanguageCode.En)">
                            下一頁：@Model.NextProfile.Names.Get(LanguageCode.ZhTW)
                        </a>
                    }
                </nav>
            </div>
        </article>

        <div class="modal fade dino-modal"
             id="dino-image-modal"
             tabindex="-1"
             aria-labelledby="dino-image-modal-title"
             aria-hidden="true"
             data-dino-modal>
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="dino-image-modal-title" data-i18n-zh-tw="@($"{Model.Profile.Names.Get(LanguageCode.ZhTW)}大圖")" data-i18n-en="@($"Large image of {Model.Profile.Names.Get(LanguageCode.En)}")">@Model.Profile.Names.Get(LanguageCode.ZhTW)大圖</h2>
                        <button type="button"
                                class="btn-close"
                                aria-label="關閉大圖"
                                data-aria-label-zh-tw="關閉大圖"
                                data-aria-label-en="Close large image"
                                data-dino-modal-close></button>
                    </div>
                    <div class="modal-body">
                        <img class="dino-modal__image"
                             src="@Model.Profile.MainImage.Path"
                             alt="@Model.Profile.MainImage.AltText.Get(LanguageCode.ZhTW)"
                             data-alt-zh-tw="@Model.Profile.MainImage.AltText.Get(LanguageCode.ZhTW)"
                             data-alt-en="@Model.Profile.MainImage.AltText.Get(LanguageCode.En)" />
                        @if (Model.Profile.MainImage.Caption is not null)
                        {
                            <p class="dino-modal__caption" data-i18n-zh-tw="@Model.Profile.MainImage.Caption.Get(LanguageCode.ZhTW)" data-i18n-en="@Model.Profile.MainImage.Caption.Get(LanguageCode.En)">@Model.Profile.MainImage.Caption.Get(LanguageCode.ZhTW)</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</section>

@section Scripts {
    <script src="~/js/dinosaurs.js" asp-append-version="true"></script>
    @if (Model.Profile is not null && !Model.IsNotFound)
    {
        <script src="~/js/passport.js" asp-append-version="true"></script>
    }
}

@page "/dinosaurs"
@model StoryBook.Pages.Dinosaurs.IndexModel
@{
    ViewData["Title"] = "恐龍介紹";
}

<section class="dino-page" aria-labelledby="dino-list-title">
    <div class="dino-page__header">
        <div>
            <p class="dino-kicker">兒童恐龍介紹</p>
            <h1 id="dino-list-title">恐龍介紹</h1>
        </div>
        <a class="dino-home-link" asp-page="/Index">回首頁</a>
    </div>

    @if (Model.FirstProfile is null)
    {
        <div class="dino-empty" role="status">
            恐龍資料暫時睡著了，請稍後再回來看看。
        </div>
    }
    else
    {
        <article class="dino-feature">
            <div class="dino-feature__media">
                <img src="@Model.FirstProfile.MainImage.Path"
                     alt="@Model.FirstProfile.MainImage.AltText.Get(LanguageCode.ZhTW)" />
            </div>
            <div class="dino-feature__body">
                <p class="dino-kicker">第一位朋友</p>
                <h2>@Model.FirstProfile.Names.Get(LanguageCode.ZhTW)</h2>
                <dl class="dino-facts">
                    <div>
                        <dt>生活時期</dt>
                        <dd>@Model.FirstProfile.Periods.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt>食性</dt>
                        <dd>@Model.FirstProfile.Diet.Get(LanguageCode.ZhTW)</dd>
                    </div>
                    <div>
                        <dt>發現地點</dt>
                        <dd>@Model.FirstProfile.DiscoveryLocations.Get(LanguageCode.ZhTW)</dd>
                    </div>
                </dl>
                <p>@Model.FirstProfile.Summary.Get(LanguageCode.ZhTW)</p>
                <a class="dino-action" asp-page="/Dinosaurs/Details" asp-route-slug="@Model.FirstProfile.Slug">
                    閱讀 @Model.FirstProfile.Names.Get(LanguageCode.ZhTW)
                </a>
            </div>
        </article>

        <section class="dino-search" aria-labelledby="dino-search-title">
            <h2 id="dino-search-title">搜尋史前朋友</h2>
            <div class="dino-search__controls">
                <input class="form-control"
                       type="search"
                       aria-label="搜尋恐龍"
                       placeholder="輸入名稱、時期、食性或地點"
                       data-dino-search-input />
                <button class="dino-clear-button" type="button" data-dino-clear-search>清除搜尋</button>
            </div>
            <p class="dino-no-results" data-dino-no-results hidden>沒有找到符合的史前朋友，清除搜尋再試一次。</p>
        </section>

        <section class="dino-directory" aria-labelledby="dino-directory-title">
            <h2 id="dino-directory-title">全部史前朋友</h2>
            <div class="dino-grid">
                @foreach (DinosaurSearchResult result in Model.SearchResults)
                {
                    <a class="dino-card"
                       asp-page="/Dinosaurs/Details"
                       asp-route-slug="@result.Slug"
                       data-dino-search-item
                       data-dino-search-text="@result.SearchText">
                        <img src="@result.ImagePath"
                             alt="@result.ImageAltText" />
                        <span>@result.Name</span>
                        <small>@result.Summary</small>
                        @if (!string.IsNullOrWhiteSpace(result.CategoryNote))
                        {
                            <em>@result.CategoryNote</em>
                        }
                    </a>
                }
            </div>
        </section>
    }
</section>

@section Scripts {
    <script src="~/js/dinosaurs.js" asp-append-version="true"></script>
}

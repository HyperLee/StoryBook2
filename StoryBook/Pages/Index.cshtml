@page
@using StoryBook.Services
@model IndexModel
@{
    ViewData["Title"] = "首頁";
}

<div class="home-hero text-center py-5">
    <h1 class="display-4">StoryBook</h1>
    <p class="lead">一起打開溫柔的故事書，認識有趣的自然朋友。</p>

    <fieldset class="theme-selector"
              data-theme-selector
              data-theme-storage-key="@Model.ThemeStorageKey"
              data-theme-default-mode="@Model.DefaultThemeMode"
              data-theme-language-storage-key="storybook.language"
              data-theme-language-fallback="zh-TW"
              aria-labelledby="theme-selector-title"
              aria-describedby="theme-selector-help">
        <legend id="theme-selector-title"
                data-i18n-zh-tw="閱讀主題"
                data-i18n-en="Reading theme">閱讀主題</legend>
        <p id="theme-selector-help"
           data-i18n-zh-tw="選擇首頁與故事頁面的亮度。"
           data-i18n-en="Choose the brightness for home and story pages.">選擇首頁與故事頁面的亮度。</p>
        <div class="theme-options">
            @foreach (ThemeModeMetadata mode in Model.ThemeModes)
            {
                string optionId = $"theme-mode-{mode.Value}";
                string descriptionId = $"{optionId}-description";
                bool isDefault = mode.Value == Model.DefaultThemeMode;

                <div class="theme-option">
                    <input class="theme-option__input"
                           type="radio"
                           id="@optionId"
                           name="storybook-theme"
                           value="@mode.Value"
                           data-theme-option="@mode.Value"
                           aria-describedby="@descriptionId"
                           checked="@isDefault" />
                    <label class="theme-option__label" for="@optionId">
                        <span class="theme-option__title"
                              data-theme-label
                              data-theme-label-zh-tw="@mode.LabelZhTW"
                              data-theme-label-en="@mode.LabelEn">@mode.LabelZhTW</span>
                        <span id="@descriptionId"
                              class="theme-option__description"
                              data-theme-description
                              data-theme-description-zh-tw="@mode.DescriptionZhTW"
                              data-theme-description-en="@mode.DescriptionEn">@mode.DescriptionZhTW</span>
                    </label>
                </div>
            }
        </div>
        <p class="visually-hidden"
           data-theme-selected-status
           data-theme-selected-status-zh-tw="目前選取：{0}"
           data-theme-selected-status-en="Selected: {0}"
           aria-live="polite"></p>
    </fieldset>

    <div class="home-actions d-flex flex-wrap justify-content-center gap-3">
        <a class="btn btn-danger btn-lg" asp-page="/Quiz/Index" data-i18n-zh-tw="問答挑戰" data-i18n-en="Quiz challenge">問答挑戰</a>
        <a class="btn btn-info btn-lg" asp-page="/Journeys/Index" data-i18n-zh-tw="學習旅程" data-i18n-en="Learning journeys">學習旅程</a>
        <a class="btn btn-secondary btn-lg" href="/passport" data-i18n-zh-tw="我的探險護照" data-i18n-en="My adventure passport">我的探險護照</a>
        <a class="btn btn-success btn-lg" asp-page="/Explore/Index" data-i18n-zh-tw="探索全部故事" data-i18n-en="Explore all stories">探索全部故事</a>
        <a class="btn btn-warning btn-lg" asp-page="/Compare/Index" data-i18n-zh-tw="比較故事朋友" data-i18n-en="Compare story friends">比較故事朋友</a>
        <a class="btn btn-primary btn-lg" asp-page="/Dinosaurs/Index">恐龍介紹</a>
        <a class="btn btn-outline-primary btn-lg" asp-page="/Aquarium/Index">水族館動物介紹</a>
    </div>
</div>

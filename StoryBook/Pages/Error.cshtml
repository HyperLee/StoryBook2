@page
@model ErrorModel
@{
    ViewData["Title"] = "發生錯誤";
}

<section class="error-page" aria-labelledby="error-title">
    <h1 id="error-title" class="error-title">故事書暫時翻不到這一頁</h1>
    <p>請回到首頁重新選一個故事，或稍後再試一次。</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <p>
        <a class="btn btn-primary" asp-page="/Index">回首頁</a>
    </p>
</section>

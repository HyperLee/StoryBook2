@page "/explore"
@using StoryBook.Models
@model StoryBook.Pages.Explore.IndexModel
@{
    ViewData["Title"] = "全站探索";
}

<section class="explore-page" aria-labelledby="explore-title">
    <div class="explore-page__header">
        <div>
            <p class="explore-kicker" data-i18n-zh-tw="全部故事朋友" data-i18n-en="All story friends">全部故事朋友</p>
            <h1 id="explore-title" data-i18n-zh-tw="全站探索" data-i18n-en="Explore all stories">全站探索</h1>
        </div>
        <a class="explore-home-link" asp-page="/Index" data-i18n-zh-tw="回首頁" data-i18n-en="Home">回首頁</a>
    </div>

    @if (Model.HasAllSourcesFailed)
    {
        <div class="explore-empty" role="status" data-explore-all-failed>
            <h2 data-i18n-zh-tw="故事資料暫時找不到" data-i18n-en="Story data cannot be found right now">故事資料暫時找不到</h2>
            <p data-i18n-zh-tw="請先回首頁，等故事朋友整理好再回來探索。" data-i18n-en="Please return home and come back when the story friends are ready.">請先回首頁，等故事朋友整理好再回來探索。</p>
            <a class="explore-action" asp-page="/Index" data-i18n-zh-tw="回首頁" data-i18n-en="Home">回首頁</a>
        </div>
    }
    else
    {
        @if (Model.HasPartialFailure)
        {
            <div class="explore-alert" role="status" data-explore-partial-failure>
                <strong data-i18n-zh-tw="有一些故事暫時躲起來了" data-i18n-en="Some stories are hiding for now">有一些故事暫時躲起來了</strong>
                @foreach (ExplorationSourceStatus status in Model.SourceStatuses.Where(status => !status.IsAvailable))
                {
                    <p data-i18n-zh-tw="@status.GetFriendlyMessage(LanguageCode.ZhTW)" data-i18n-en="@status.GetFriendlyMessage(LanguageCode.En)">
                        @status.GetFriendlyMessage(LanguageCode.ZhTW)
                    </p>
                }
            </div>
        }

        <section class="explore-search" aria-labelledby="explore-search-title" data-explore-search-updates-within-ms="1000">
            <h2 id="explore-search-title" data-i18n-zh-tw="搜尋全部故事" data-i18n-en="Search all stories">搜尋全部故事</h2>
            <div class="explore-search__controls">
                <input class="form-control"
                       type="search"
                       aria-label="搜尋全部故事"
                       placeholder="輸入名稱、食性、生活區域、時期或地點"
                       data-aria-label-zh-tw="搜尋全部故事"
                       data-aria-label-en="Search all stories"
                       data-placeholder-zh-tw="輸入名稱、食性、生活區域、時期或地點"
                       data-placeholder-en="Search by name, diet, home, period, or place"
                       data-explore-search-input />
                <button class="explore-clear-button"
                        type="button"
                        data-explore-clear-search
                        data-i18n-zh-tw="清除搜尋"
                        data-i18n-en="Clear search">清除搜尋</button>
            </div>
            <p class="explore-result-status"
               data-explore-result-status
               data-all-template-zh-tw="目前顯示 {0} 位故事朋友。"
               data-all-template-en="Showing {0} story friends."
               data-search-template-zh-tw="找到 {0} 位符合搜尋的故事朋友。"
               data-search-template-en="Found {0} story friends for your search."
               aria-live="polite">目前顯示 @Model.Items.Count 位故事朋友。</p>
            <p class="explore-search-message"
               data-explore-too-short
               data-i18n-zh-tw="請輸入至少兩個字，故事朋友比較找得到。"
               data-i18n-en="Please type at least two characters so story friends are easier to find."
               hidden>請輸入至少兩個字，故事朋友比較找得到。</p>
            <p class="explore-search-message"
               data-explore-no-results
               data-i18n-zh-tw="沒有找到符合的故事朋友，清除搜尋再試一次。"
               data-i18n-en="No story friend matched. Clear the search and try again."
               hidden>沒有找到符合的故事朋友，清除搜尋再試一次。</p>
        </section>

        <section class="explore-results" aria-labelledby="explore-results-title">
            <div class="explore-section-heading">
                <h2 id="explore-results-title" data-i18n-zh-tw="全部故事朋友" data-i18n-en="All story friends">全部故事朋友</h2>
                <p data-i18n-zh-tw="先依故事書分組，再照原本故事順序排列。" data-i18n-en="Grouped by storybook, then kept in the original story order.">先依故事書分組，再照原本故事順序排列。</p>
            </div>

            @foreach (IGrouping<ExplorationSourceType, ExplorationItem> sourceGroup in Model.Items.GroupBy(item => item.Source).OrderBy(group => group.Key.GetSortOrder()))
            {
                string sourceCode = sourceGroup.Key.ToCode();
                <section class="explore-source-section" aria-labelledby="explore-source-@sourceCode">
                    <h3 id="explore-source-@sourceCode" data-i18n-zh-tw="@sourceGroup.Key.GetLabel(LanguageCode.ZhTW)" data-i18n-en="@sourceGroup.Key.GetLabel(LanguageCode.En)">
                        @sourceGroup.Key.GetLabel(LanguageCode.ZhTW)
                    </h3>
                    <div class="explore-grid">
                        @foreach (ExplorationItem item in sourceGroup.OrderBy(item => item.SortOrder))
                        {
                            string facetMetadata = string.Join(" ", item.Facets.Select(facet => $"{facet.GroupCode}:{facet.ValueCode}"));

                            <article class="explore-card"
                                     data-explore-result-item
                                     data-explore-source="@item.Source.ToCode()"
                                     data-explore-search-text="@item.SearchText"
                                     data-explore-facets="@facetMetadata">
                                <a class="explore-card__link" href="@item.DetailHref">
                                    <span class="explore-card__media">
                                        <img src="@item.ImagePath"
                                             alt="@item.GetImageAltText(LanguageCode.ZhTW)"
                                             data-alt-zh-tw="@item.GetImageAltText(LanguageCode.ZhTW)"
                                             data-alt-en="@item.GetImageAltText(LanguageCode.En)" />
                                        <span class="explore-card__image-fallback"
                                              data-i18n-zh-tw="圖片暫時沒有出現，但故事還在。"
                                              data-i18n-en="The picture is not here right now, but the story is ready.">圖片暫時沒有出現，但故事還在。</span>
                                    </span>
                                    <span class="explore-card__body">
                                        <span class="explore-card__source"
                                              data-i18n-zh-tw="@item.GetSourceLabel(LanguageCode.ZhTW)"
                                              data-i18n-en="@item.GetSourceLabel(LanguageCode.En)">@item.GetSourceLabel(LanguageCode.ZhTW)</span>
                                        <span class="explore-card__title"
                                              data-i18n-zh-tw="@item.GetName(LanguageCode.ZhTW)"
                                              data-i18n-en="@item.GetName(LanguageCode.En)">@item.GetName(LanguageCode.ZhTW)</span>
                                        <span class="explore-card__summary"
                                              data-i18n-zh-tw="@item.GetSummary(LanguageCode.ZhTW)"
                                              data-i18n-en="@item.GetSummary(LanguageCode.En)">@item.GetSummary(LanguageCode.ZhTW)</span>
                                        <span class="explore-card__action" data-i18n-zh-tw="閱讀故事" data-i18n-en="Read story">閱讀故事</span>
                                    </span>
                                </a>
                            </article>
                        }
                    </div>
                </section>
            }
        </section>
    }
</section>

@section Scripts {
    <script src="~/js/explore.js" asp-append-version="true"></script>
}
